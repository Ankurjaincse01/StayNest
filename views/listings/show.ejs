<% layout("/layouts/boilerplate") %>

<div class="container show-container">
    <!-- Title Section -->
    <div class="show-header">
        <h2 class="show-title"><%= listing.title %></h2>
        <p class="show-location-top">
            <i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %>
        </p>
    </div>

    <!-- Image Section -->
    <div class="show-image-wrapper">
        <img src="<%= listing.image && listing.image.url ? listing.image.url : 'https://via.placeholder.com/800x600?text=No+Image' %>" 
             class="show-img" 
             alt="listing_image">
    </div>

    <% 
    const isOwner = currUser && listing.owner && 
        (listing.owner._id ? listing.owner._id.equals(currUser._id) : listing.owner.equals(currUser._id));
    %>

    <!-- Info Section -->
    <div class="show-info">
        <h3 class="info-title">Entire place hosted by <%= listing.owner ? listing.owner.name || listing.owner.email : 'StayNest Host' %></h3>
        <p class="show-description"><%= listing.description %></p>
    </div>

    <!-- Reservation Card - After Description -->
    <div class="reservation-card-inline">
        <div class="price-header">
            <h3>&#8377 <%= listing.price.toLocaleString("en-IN") %> <span class="per-night">/ night</span></h3>
        </div>
        
        <% if (currUser && !isOwner) { %>
        <!-- Reservation Form -->
        <form action="/bookings/listings/<%= listing._id %>/book" method="POST" id="bookingForm" class="reservation-form">
            <div class="booking-inputs-row">
                <div class="date-inputs">
                    <div class="date-group">
                        <label for="checkIn">CHECK-IN</label>
                        <input type="date" id="checkIn" name="checkIn" required>
                    </div>
                    <div class="date-group">
                        <label for="checkOut">CHECKOUT</label>
                        <input type="date" id="checkOut" name="checkOut" required>
                    </div>
                </div>

                <div class="guests-input">
                    <label for="guests">GUESTS</label>
                    <select id="guests" name="guests" required>
                        <option value="">Select guests</option>
                        <option value="1">1 guest</option>
                        <option value="2">2 guests</option>
                        <option value="3">3 guests</option>
                        <option value="4">4 guests</option>
                        <option value="5">5 guests</option>
                        <option value="6">6+ guests</option>
                    </select>
                </div>

                <button type="submit" class="btn-reserve">Reserve</button>
            </div>

            <div class="price-breakdown" id="priceBreakdown" style="display: none;">
                <div class="price-row">
                    <span>&#8377 <%= listing.price.toLocaleString() %> × <span id="nights">0</span> nights</span>
                    <span>&#8377 <span id="subtotal">0</span></span>
                </div>
                <div class="price-row">
                    <span>Service fee (10%)</span>
                    <span>&#8377 <span id="serviceFee">0</span></span>
                </div>
                <hr>
                <div class="price-row total">
                    <strong>Total</strong>
                    <strong>&#8377 <span id="total">0</span></strong>
                </div>
            </div>
        </form>
        <% } else if (!currUser) { %>
        <div class="booking-inputs-row">
            <div class="date-inputs">
                <div class="date-group">
                    <label>CHECK-IN</label>
                    <input type="date" disabled placeholder="Add date">
                </div>
                <div class="date-group">
                    <label>CHECKOUT</label>
                    <input type="date" disabled placeholder="Add date">
                </div>
            </div>
            <div class="guests-input">
                <label>GUESTS</label>
                <select disabled>
                    <option>Select guests</option>
                </select>
            </div>
            <a href="/login" class="btn-reserve">Login to Book</a>
        </div>
        <% } else if (isOwner) { %>
        <div class="booking-inputs-row">
            <div class="date-inputs">
                <div class="date-group">
                    <label>CHECK-IN</label>
                    <input type="date" disabled>
                </div>
                <div class="date-group">
                    <label>CHECKOUT</label>
                    <input type="date" disabled>
                </div>
            </div>
            <div class="guests-input">
                <label>GUESTS</label>
                <select disabled>
                    <option>Select guests</option>
                </select>
            </div>
        </div>
        <div class="owner-message">
            <p><i class="fa-solid fa-circle-info"></i> You own this listing</p>
        </div>
        <% } %>
    </div>

    <% if (isOwner) { %>
    <!-- Action Buttons -->
    <div class="show-actions">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">Edit</a>
        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline ms-2">
            <button class="btn btn-dark">Delete</button>
        </form>
    </div>
    <hr>
    <% } %>

    <!-- Map Section -->
    <div class="show-map-section">
        <h4>Where you'll be</h4>
        <div id="map" style="height: 400px; border-radius: 1rem;"></div>
    </div>

    <% if(currUser && !isOwner) { %>
    <!-- Review Form -->
    <div class="show-review-form">
        <hr>
        <h4>Leave a Review</h4>
        <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
            <div class="mb-3">
                <div class="star-rating">
                    <input type="radio" id="star5" name="review[rating]" value="5" />
                    <label for="star5" title="5 stars">★</label>
                    <input type="radio" id="star4" name="review[rating]" value="4" />
                    <label for="star4" title="4 stars">★</label>
                    <input type="radio" id="star3" name="review[rating]" value="3" />
                    <label for="star3" title="3 stars">★</label>
                    <input type="radio" id="star2" name="review[rating]" value="2" />
                    <label for="star2" title="2 stars">★</label>
                    <input type="radio" id="star1" name="review[rating]" value="1" />
                    <label for="star1" title="1 star">★</label>
                </div>
            </div>
            <div class="mb-3 mt-3"> 
                <label for="comment" class="form-label">Comments</label>
                <textarea name="review[comment]" id="comment" cols="30" rows="4" class="form-control" required></textarea>
                <div class="invalid-feedback">Please add some comments for review</div>
            </div>
            <button class="btn btn-dark">Submit Review</button>
        </form>
    </div>
    <% } %>

    <% if(listing.reviews && listing.reviews.length > 0) { %>
    <!-- All Reviews -->
    <div class="show-reviews">
        <hr>
        <h4>All Reviews</h4>
        <div class="row">
            <% for(let review of listing.reviews) { %>
            <div class="col-md-6 mb-3">
                <div class="review-card">
                    <div class="review-header">
                        <h5>@<%= review.author.name || review.author.email || "Anonymous" %></h5>
                        <p class="review-stars">
                            <% for(let i = 1; i <= 5; i++) { %>
                            <span class="<%= i <= review.rating ? 'star-filled' : 'star-empty' %>">★</span>
                            <% } %>
                        </p>
                    </div>
                    <p class="review-comment"><%= review.comment %></p>
                    <% if(currUser && review.author._id.equals(currUser._id)) { %>
                    <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="d-inline">
                        <button class="btn btn-sm btn-outline-dark">Delete</button>
                    </form>
                    <% } %>
                </div>
            </div>
            <% } %>
        </div>
    </div>
    <% } %>
    </div>
</div>

<style>
.show-container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
}

.show-header {
    margin-bottom: 1.5rem;
}

.show-title {
    font-size: 26px;
    font-weight: 600;
    color: #222;
    margin-bottom: 0.5rem;
}

.show-location-top {
    font-size: 14px;
    color: #222;
    margin: 0;
}

.show-location-top i {
    margin-right: 4px;
}

.show-image-wrapper {
    border-radius: 12px;
    overflow: hidden;
    height: 500px;
    margin-bottom: 2rem;
}

.show-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.reservation-card-inline {
    background: white;
    border: 1px solid #ddd;
    border-radius: 12px;
    padding: 24px;
    margin-bottom: 3rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.price-header {
    margin-bottom: 20px;
}

.price-header h3 {
    font-size: 22px;
    font-weight: 600;
    color: #222;
    margin: 0;
}

.price-header .per-night {
    font-size: 16px;
    font-weight: 400;
    color: #222;
}

.booking-inputs-row {
    display: grid;
    grid-template-columns: 2fr 1fr auto;
    gap: 12px;
    align-items: end;
}

.date-inputs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 1px solid #b0b0b0;
    border-radius: 8px;
    overflow: hidden;
}

.date-group {
    padding: 12px;
    position: relative;
}

.date-group:first-child {
    border-right: 1px solid #b0b0b0;
}

.date-group label {
    display: block;
    font-size: 10px;
    font-weight: 800;
    color: #222;
    margin-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.date-group input {
    border: none;
    width: 100%;
    font-size: 14px;
    color: #222;
    padding: 0;
    outline: none;
    background: transparent;
    font-family: inherit;
}

.guests-input {
    border: 1px solid #b0b0b0;
    border-radius: 8px;
    padding: 12px;
}

.guests-input label {
    display: block;
    font-size: 10px;
    font-weight: 800;
    color: #222;
    margin-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.guests-input select {
    border: none;
    width: 100%;
    font-size: 14px;
    color: #222;
    padding: 0;
    outline: none;
    background: transparent;
    font-family: inherit;
    cursor: pointer;
}

.btn-reserve {
    background: #222;
    color: white;
    border: none;
    padding: 14px 24px;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    white-space: nowrap;
    text-decoration: none;
    display: inline-block;
    text-align: center;
}

.btn-reserve:hover {
    background: #000;
    color: white;
    text-decoration: none;
}

.no-charge {
    text-align: center;
    color: #717171;
    font-size: 14px;
    margin-top: 12px;
    margin-bottom: 0;
}

.price-breakdown {
    margin-top: 20px;
    padding-top: 20px;
}

.price-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 12px;
    font-size: 16px;
    color: #222;
}

.price-row.total {
    padding-top: 16px;
    border-top: 1px solid #ddd;
    font-size: 16px;
}

.price-breakdown hr {
    display: none;
}

.owner-message {
    text-align: center;
    padding: 16px;
    background: #f7f7f7;
    border-radius: 8px;
    margin-top: 12px;
}

.owner-message p {
    color: #222;
    margin: 0;
    font-size: 14px;
    font-weight: 500;
}

.owner-message i {
    margin-right: 6px;
}

.reservation-note {
    text-align: center;
    color: #717171;
    font-size: 14px;
    margin-top: 12px;
    margin-bottom: 0;
}

.show-info {
    padding: 2rem 0;
}

.info-title {
    font-size: 22px;
    font-weight: 600;
    color: #222;
    margin-bottom: 1rem;
}

.show-description {
    font-size: 16px;
    color: #222;
    line-height: 1.6;
}

.show-actions {
    padding: 1rem 0;
}

@media (max-width: 768px) {
    .booking-inputs-row {
        grid-template-columns: 1fr;
        gap: 12px;
    }
    
    .show-image-wrapper {
        height: 300px;
    }
}
</style>

<script>
// Calculate billing when dates change
const checkInInput = document.getElementById('checkIn');
const checkOutInput = document.getElementById('checkOut');
const priceBreakdown = document.getElementById('priceBreakdown');
const pricePerNight = <%= listing.price %>;

// Set minimum date to today
const today = new Date().toISOString().split('T')[0];
if (checkInInput) {
    checkInInput.min = today;
}

function calculateBilling() {
    if (!checkInInput || !checkOutInput) return;
    
    const checkIn = new Date(checkInInput.value);
    const checkOut = new Date(checkOutInput.value);
    
    if (checkIn && checkOut && checkOut > checkIn) {
        const nights = Math.ceil((checkOut - checkIn) / (1000 * 60 * 60 * 24));
        const subtotal = pricePerNight * nights;
        const serviceFee = Math.round(subtotal * 0.1);
        const total = subtotal + serviceFee;
        
        document.getElementById('nights').textContent = nights;
        document.getElementById('subtotal').textContent = subtotal.toLocaleString('en-IN');
        document.getElementById('serviceFee').textContent = serviceFee.toLocaleString('en-IN');
        document.getElementById('total').textContent = total.toLocaleString('en-IN');
        
        priceBreakdown.style.display = 'block';
    } else {
        priceBreakdown.style.display = 'none';
    }
}

if (checkInInput) {
    checkInInput.addEventListener('change', function() {
        checkOutInput.min = this.value;
        calculateBilling();
    });
}

if (checkOutInput) {
    checkOutInput.addEventListener('change', calculateBilling);
}

// Expose listing data to JavaScript
window.listing = <%- JSON.stringify(listing) %>;

// Initialize Leaflet Map with delay to ensure DOM is ready
setTimeout(function() {
  const mapElement = document.getElementById('map');
  if (mapElement && window.listing && typeof L !== 'undefined') {
    try {
      // Get coordinates from listing or use default
      let coordinates = [28.6139, 77.2090]; // Default: New Delhi
      
      if (window.listing.geometry && window.listing.geometry.coordinates && window.listing.geometry.coordinates.length === 2) {
        // GeoJSON format is [longitude, latitude], Leaflet uses [latitude, longitude]
        coordinates = [window.listing.geometry.coordinates[1], window.listing.geometry.coordinates[0]];
      }
      
      var map = L.map('map').setView(coordinates, 13);
      
      L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '&copy; <a href="http://www.openstreetmap.org/copyright">OpenStreetMap</a>'
      }).addTo(map);
      
      // Create custom popup
      var popupContent = `
        <div style="text-align: center;">
          <h5 style="margin: 0 0 10px 0; color: #e74c3c;">${window.listing.title || 'Listing'}</h5>
          <p style="margin: 5px 0;"><strong>📍 ${window.listing.location || 'Location'}</strong></p>
          <p style="margin: 5px 0; font-size: 0.9em; color: #666;">Exact location provided after booking</p>
        </div>
      `;
      
      // Create red marker with popup
      var marker = L.marker(coordinates, {
        icon: L.icon({
          iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-red.png',
          shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/images/marker-shadow.png',
          iconSize: [25, 41],
          iconAnchor: [12, 41],
          popupAnchor: [1, -34],
          shadowSize: [41, 41]
        })
      })
      .addTo(map)
      .bindPopup(popupContent, {
        maxWidth: 300,
        className: 'custom-popup'
      });
      
      // Open popup by default
      marker.openPopup();
      
    } catch (error) {
      console.error('Map initialization error:', error);
    }
  }
}, 100);
</script>