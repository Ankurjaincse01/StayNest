<% layout("/layouts/boilerplate") %>

  <style>
    .filter-section {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.5rem 0;
      margin-bottom: 1rem;
      gap: 2rem;
    }

    #filters {
      display: flex;
      overflow-x: auto;
      gap: 2rem;
      flex: 1;
    }

    #filters::-webkit-scrollbar {
      height: 0;
    }
  </style>

  <div class="filter-section">
    <div id="filters">
      <a href="/listings" class="filter" data-category="">
        <i class="fa-solid fa-folder"></i>
        <span>Trending</span>
      </a>
      <a href="/listings?category=Rooms" class="filter" data-category="Rooms">
        <i class="fa-solid fa-bed"></i>
        <span>Rooms</span>
      </a>
      <a href="/listings?category=Villa" class="filter" data-category="Villa">
        <i class="fa-solid fa-house"></i>
        <span>Villa</span>
      </a>
      <a href="/listings?category=Cabins" class="filter" data-category="Cabins">
        <i class="fa-solid fa-campground"></i>
        <span>Cabins</span>
      </a>
      <a href="/listings?category=Pool House" class="filter" data-category="Pool House">
        <i class="fa-solid fa-person-swimming"></i>
        <span>Amazing Pools</span>
      </a>
      <a href="/listings?category=PG" class="filter" data-category="PG">
        <i class="fa-solid fa-user-group"></i>
        <span>PG</span>
      </a>
      <a href="/listings?category=Farm House" class="filter" data-category="Farm House">
        <i class="fa-solid fa-tractor"></i>
        <span>Farms</span>
      </a>
      <a href="/listings?category=Flat" class="filter" data-category="Flat">
        <i class="fa-solid fa-building"></i>
        <span>Flat</span>
      </a>
      <a href="/listings?category=Beachfront" class="filter" data-category="Beachfront">
        <i class="fa-solid fa-umbrella-beach"></i>
        <span>Beachfront</span>
      </a>
    </div>

    <div class="tax-toggle">
      <span>Display total before taxes</span>
      <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
      </div>
    </div>
  </div>

  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">

    <!-- <form method="get" action="/listings/new">
        <button>create new listing</button>
    </form> -->
    <% for(let listing of alllisting){ %>
      <a href="/listings/<%= listing._id %>" class="listing-link mt-3">
        <div class="card  listing-card">
          <img
            src="<%= listing.image && listing.image.url ? listing.image.url : 'https://via.placeholder.com/800x600?text=No+Image' %>"
            class="card-img-top" alt="listing_image" style="height: 20rem;">
          <div class="card-img-overlay"></div>
          <div class="card-body">
            <p class="card-text">
              <B>
                <%=listing.title %>
              </B>
              <br>
              <span class="listing-price">&#8377 <%= listing.price.toLocaleString("en-IN")%></span>
              <span class="listing-price-with-tax" style="display: none;">&#8377 <%= (listing.price *
                  1.18).toLocaleString("en-IN", {maximumFractionDigits: 0})%></span>
              / night
              <i class="tax-info">+18% GST</i>
            </p>
          </div>
        </div>
      </a>
      <% } %>

  </div>

  <script>
    let taxSwitch = document.getElementById("flexSwitchCheckDefault");
    taxSwitch.addEventListener("click", () => {
      let taxInfoElements = document.querySelectorAll(".tax-info");
      let priceElements = document.querySelectorAll(".listing-price");
      let priceWithTaxElements = document.querySelectorAll(".listing-price-with-tax");

      if (taxSwitch.checked) {
        // Show price with tax included
        taxInfoElements.forEach((el) => el.style.display = "none");
        priceElements.forEach((el) => el.style.display = "none");
        priceWithTaxElements.forEach((el) => el.style.display = "inline");
      } else {
        // Show original price with GST label
        taxInfoElements.forEach((el) => el.style.display = "inline");
        priceElements.forEach((el) => el.style.display = "inline");
        priceWithTaxElements.forEach((el) => el.style.display = "none");
      }
    });

    // Handle filter active state
    const urlParams = new URLSearchParams(window.location.search);
    const activeCategory = urlParams.get('category');
    const filters = document.querySelectorAll('.filter');

    filters.forEach(filter => {
      const filterCategory = filter.getAttribute('data-category');
      if (!activeCategory && !filterCategory) {
        filter.classList.add('active');
      } else if (activeCategory === filterCategory) {
        filter.classList.add('active');
      }
    });
  </script>